{
  "name": "porcelain",
  "version": "0.2.0",
  "description": "Review changes as a story",
  "main": "./out/main/index.js",
  "author": "Fabio Fiorita",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FabioFiorita/porcelain.git"
  },
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome check .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --mac --publish never",
    "release": "npm run build && electron-builder --mac --publish always",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -r 0",
    "version": "pnpm changelog && git add CHANGELOG.md"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@trpc/server": "^10.45.4",
    "electron-trpc": "^0.7.1",
    "electron-updater": "^6.8.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@biomejs/biome": "^2.5.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^4.44.0",
    "@tanstack/react-virtual": "^3.14.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@trpc/client": "^10.45.4",
    "@trpc/react-query": "^10.45.4",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tiptap-markdown": "^0.9.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.8",
    "zustand": "^5.0.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
