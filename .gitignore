node_modules/
dist/
dist-daemon/
out/
.DS_Store

# Playwright e2e: keep the *-snapshots/ baselines (committed), drop run output.
test-results/
playwright-report/
e2e/.artifacts/

# Playwright MCP (agent browser drive) dumps page-*.yml / console logs at repo root.
# Never commit; delete the dir when the drive is done (see CLAUDE.md).
.playwright-mcp/

# Agent worktrees (improve/execute isolation) — never track these
.claude/worktrees/

# Marketing screenshots produced by `pnpm shots` — regenerated, not tracked.
marketing/shots/

# Ephemeral agent automation (one-off shot scripts, local harnesses, tmp PNG dumps).
# See CLAUDE.md / AGENTS.md — agents may write freely under scripts/agent-scratch/.
scripts/agent-scratch/

# TypeScript incremental build cache
*.tsbuildinfo

# Claude Design handoff bundle — a local prototype reference, not source. Keep it
# out of git and out of the lint/typecheck gate (Biome honours .gitignore).
claude-design/
src/renderer/public/excalidraw-assets/
