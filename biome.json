{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "**",
      "!.agents",
      "!marketing",
      "!plugins/porcelain/server.js",
      "!src/renderer/src/components/ui",
      "!**/*.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": { "quoteStyle": "single", "semicolons": "asNeeded" }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": { "noExplicitAny": "error" }
    }
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "overrides": [
    {
      "includes": ["src/renderer/src/components/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@renderer/lib/trpc": "Components must reach the server through hooks in @renderer/hooks/* — never import lib/trpc directly.",
                  "../lib/trpc": "Components must reach the server through hooks in @renderer/hooks/* — never import lib/trpc directly.",
                  "../../lib/trpc": "Components must reach the server through hooks in @renderer/hooks/* — never import lib/trpc directly."
                }
              }
            }
          }
        }
      }
    }
  ]
}
